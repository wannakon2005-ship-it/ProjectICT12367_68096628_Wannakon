<!DOCTYPE html>
<html lang="th">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>สมัครสมาชิก | ร้านซักรีด</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">

    <style>
        body {
            /* โทนสีพื้นหลังเดียวกับหน้า Login */
            background: linear-gradient(135deg, #e0c3fc 0%, #8ec5fc 100%);
            font-family: 'Prompt', sans-serif;
            height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
        }

        .login-wrapper {
            width: 100%;
            max-width: 450px; 
            padding: 20px;
        }

        .login-box {
            background: rgba(255, 255, 255, 0.98);
            border-radius: 20px;
            box-shadow: 0 15px 35px rgba(0,0,0,0.15);
            padding: 40px 30px;
            border: 1px solid rgba(255, 255, 255, 0.5);
        }

        .icon-header {
            font-size: 3rem;
            color: #4facfe;
            margin-bottom: 10px;
        }

        /* ปรับแต่งช่องกรอกข้อมูล */
        .input-group-text {
            background-color: transparent;
            border-right: none;
            border-radius: 10px 0 0 10px;
        }

        .form-control {
            border-left: none;
            border-radius: 0 10px 10px 0;
            padding: 12px 15px 12px 0;
        }

        .form-control:focus {
            box-shadow: none;
            border-color: #dee2e6;
        }

        .input-group:focus-within {
            box-shadow: 0 0 0 0.25rem rgba(79, 172, 254, 0.25);
            border-radius: 10px;
        }

        /* ปรับแต่งปุ่ม Submit */
        .btn-register-submit {
            background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
            border: none;
            border-radius: 10px;
            padding: 12px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

        .btn-register-submit:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(79, 172, 254, 0.4);
        }
    </style>
</head>

<body>

<div class="login-wrapper">
    <div class="login-box text-center">
        <div class="icon-header">
            <i class="fa-solid fa-user-plus"></i>
        </div>
        
        <h4 class="mb-1 fw-bold">สมัครสมาชิก</h4>
        <p class="text-muted mb-4 fs-6">กรอกข้อมูลเพื่อเปิดบัญชีร้านซักรีด</p>

        {% if messages %}
            {% for message in messages %}
                {% if message.tags %}
                    <div class="alert alert-{{ message.tags }} py-2 mb-3 text-start fs-6" role="alert">
                        {% if 'success' in message.tags %}
                            <i class="fa-solid fa-circle-check me-1"></i>
                        {% else %}
                            <i class="fa-solid fa-circle-exclamation me-1"></i>
                        {% endif %}
                        {{ message }}
                    </div>
                {% else %}
                    <div class="alert alert-info py-2 mb-3 text-start fs-6" role="alert">
                        <i class="fa-solid fa-circle-info me-1"></i> {{ message }}
                    </div>
                {% endif %}
            {% endfor %}
        {% endif %}

        <form method="POST">
            {% csrf_token %}

            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fa-solid fa-user text-muted"></i></span>
                <input type="text" name="username" class="form-control" placeholder="ชื่อผู้ใช้ (Username)" required>
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fa-solid fa-phone text-muted"></i></span>
                <input type="text" name="telephone" class="form-control" placeholder="เบอร์โทรศัพท์ (เช่น 0812345678)" required>
            </div>

            <div class="input-group mb-3">
                <span class="input-group-text"><i class="fa-solid fa-lock text-muted"></i></span>
                <input type="password" name="password" id="id_password" class="form-control" placeholder="รหัสผ่าน (6 ตัวขึ้นไป)" required>
                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('id_password', this)">
                <i class="fa-solid fa-eye"></i>
            </button>
            </div>

            <div class="input-group mb-4">
                <span class="input-group-text"><i class="fa-solid fa-key text-muted"></i></span>
                <input type="password" name="confirm_password" id="id_confirm_password" class="form-control" placeholder="ยืนยันรหัสผ่าน" required>
                <button class="btn btn-outline-secondary" type="button" onclick="togglePassword('id_confirm_password', this)">
                <i class="fa-solid fa-eye"></i>
                </button>
            </div>

            <button type="submit" class="btn btn-register-submit w-100 text-white shadow-sm">
                ลงทะเบียน
            </button>

            <div class="mt-4">
                <span class="text-muted small">มีบัญชีอยู่แล้ว?</span>
                <a href="/" class="text-decoration-none small text-primary fw-bold ms-1">เข้าสู่ระบบที่นี่</a>
            </div>
        </form>
    </div>
</div>

<script>
function togglePassword(inputId, btn) {
    var input = document.getElementById(inputId);
    var icon = btn.querySelector('i');
    
    if (input.type === "password") {
        input.type = "text";
        icon.classList.remove('fa-eye');
        icon.classList.add('fa-eye-slash'); // เปลี่ยนเป็นรูปดวงตาขีดฆ่า
    } else {
        input.type = "password";
        icon.classList.remove('fa-eye-slash');
        icon.classList.add('fa-eye'); // กลับมาเป็นรูปดวงตาปกติ
    }
}
</script>

</body>
</html>